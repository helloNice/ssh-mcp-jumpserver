{
  "servers": {
    "ssh": {
      "command": "npx",
      "args": [
        "ssh-mcp-jumpserver"
      ],
      "env": {
        "JUMPSERVER_URL": "https://your-jumpserver.example.com",
        "JUMPSERVER_KEY_ID": "your-key-id",
        "JUMPSERVER_SECRET_ID": "your-secret-id"
      }
    }
  }
}
